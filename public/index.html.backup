<!-- UX FIXES v2 - Melhorias de conversão -->
<script>
(function() {
    'use strict';
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initUXFixes);
    } else {
        initUXFixes();
    }
    
    function initUXFixes() {
        enhanceHeroCTA();
        createSlotsIndicator();
        // createTrustTicker(); // REMOVIDO - redundante com hero badge
        createMobileFAB();
        setupEnhancedTracking();
        initCredentialsExpand();
    }
    
    // 0. Credentials strip expand/collapse
    function initCredentialsExpand() {
        var btn = document.getElementById('credExpandBtn');
        var panel = document.getElementById('credExpandPanel');
        if (!btn || !panel) return;
        
        btn.addEventListener('click', function() {
            var isExpanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', String(!isExpanded));
            panel.setAttribute('aria-hidden', String(isExpanded));
            
            if (!isExpanded) {
                panel.classList.add('is-open');
                btn.classList.add('is-open');
                if (typeof gtag === 'function') {
                    gtag('event', 'track_record_expanded', { event_category: 'engagement' });
                }
            } else {
                panel.classList.remove('is-open');
                btn.classList.remove('is-open');
            }
        });
    }
    
    // 1. REMOVED: enhanceHeroCTA() — was overriding HTML CTA copy with conflicting text
    //    Original "Fazer Assessment Gratuito" is clearer and matches page context.
    //    The data-i18n attribute handles language switching natively.
    function enhanceHeroCTA() { /* noop — preserved to avoid breaking initUXFixes call */ }
    
    // 2. REMOVED: createSlotsIndicator() — was injecting "1 vaga disponível Q1" which
    //    contradicted the HTML scarcity badge showing "3 vagas disponíveis para Q1 2026".
    //    The single source of truth is now the HTML .scarcity-badge element.
    function createSlotsIndicator() { /* noop — preserved to avoid breaking initUXFixes call */ }
    
    // 4. Mobile FAB - CTA fixo após scroll
    function createMobileFAB() {
        // DISABLED: FAB is now static HTML element (#mobileFab)
        return;
        if (window.innerWidth > 767 || document.querySelector('.mobile-fab')) return;
        
        var lang = document.documentElement.lang === 'en' ? 'en' : 'pt';
        var copy = { pt: 'Fazer Assessment Gratuito', en: 'Take Free Assessment' };
        
        var fab = document.createElement('div');
        fab.className = 'mobile-fab';
        fab.innerHTML = '<a href="assessment.html" class="mobile-fab-btn"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg><span>' + copy[lang] + '</span></a>';
        document.body.appendChild(fab);
        
        var fabShown = false;
        function showFAB() {
            if (fabShown) return;
            fab.classList.add('visible');
            document.body.classList.add('fab-active');
            fabShown = true;
            if (typeof gtag === 'function') {
                gtag('event', 'mobile_fab_shown', { event_category: 'ux_experiment' });
            }
        }
        
        window.addEventListener('scroll', function() {
            var scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
            if (scrollPercent > 25) showFAB();
        }, { passive: true });
        
        setTimeout(showFAB, 3000);
        
        fab.querySelector('.mobile-fab-btn').addEventListener('click', function() {
            if (typeof gtag === 'function') {
                gtag('event', 'cta_click', { cta_type: 'assessment', location: 'mobile_fab' });
            }
        });
    }
    
    // 5. Enhanced tracking
    function setupEnhancedTracking() {
        if (typeof gtag !== 'function') return;
        
        var heroCtaObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    gtag('event', 'hero_cta_visible', { event_category: 'visibility', viewport_width: window.innerWidth });
                    heroCtaObserver.disconnect();
                }
            });
        }, { threshold: 0.5 });
        
        var heroCta = document.querySelector('.btn-hero');
        if (heroCta) heroCtaObserver.observe(heroCta);
    }
    
    // Re-apply on language change
    var langObserver = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
            if (mutation.attributeName === 'lang') {
                setTimeout(function() {
                    var si = document.querySelector('.slots-indicator'); if (si) si.remove();
                    // var tt = document.querySelector('.trust-ticker'); if (tt) tt.remove(); // REMOVIDO
                    var mf = document.querySelector('.mobile-fab'); if (mf) mf.remove();
                    enhanceHeroCTA();
                    createSlotsIndicator();
                    // createTrustTicker(); // REMOVIDO
                    createMobileFAB();
                }, 100);
            }
        });
    });
    langObserver.observe(document.documentElement, { attributes: true });
})();
</script>

<!-- UX FIX: Unified Mobile Bottom Bar (replaces 3 competing fixed elements) -->
<!-- Combines: mobile-sticky-cta + whatsapp-float into one coordinated bar on mobile -->
<div class="mobile-bottom-bar" id="mobileBottomBar">
    <div class="mobile-bottom-inner">
        <a href="assessment.html" class="mobile-bottom-primary" id="mobileBottomCTA">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 11l3 3L22 4"/>
                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
            </svg>
            <span data-i18n="mobile.cta">Diagnóstico Gratuito</span>
        </a>
        <a href="https://wa.me/5511975341961" target="_blank" rel="noopener" class="mobile-bottom-whatsapp" aria-label="WhatsApp">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
        </a>
    </div>
</div>

<script>
// UNIFIED Mobile Bottom Bar Logic (replaces old mobileCTA + FAB coordination)
(function() {
    'use strict';
    var bar = document.getElementById('mobileBottomBar');
    if (!bar) return;
    
    var hero = document.querySelector('.hero');
    var ctaFinal = document.getElementById('contato');
    var barVisible = false;
    
    function updateBarVisibility() {
        if (window.innerWidth > 767) {
            bar.classList.remove('visible');
            return;
        }
        
        var scrollY = window.pageYOffset || window.scrollY;
        var pastHero = hero ? scrollY > hero.offsetHeight * 0.8 : scrollY > 400;
        
        // Hide when user reaches the final CTA section (avoid redundancy)
        var nearFinalCTA = false;
        if (ctaFinal) {
            var ctaRect = ctaFinal.getBoundingClientRect();
            nearFinalCTA = ctaRect.top < window.innerHeight * 0.7;
        }
        
        if (pastHero && !nearFinalCTA) {
            if (!barVisible) {
                bar.classList.add('visible');
                barVisible = true;
            }
        } else {
            if (barVisible) {
                bar.classList.remove('visible');
                barVisible = false;
            }
        }
    }
    
    // Throttled scroll listener
    var ticking = false;
    window.addEventListener('scroll', function() {
        if (!ticking) {
            window.requestAnimationFrame(function() {
                updateBarVisibility();
                ticking = false;
            });
            ticking = true;
        }
    }, { passive: true });
    
    // Also check on resize (orientation change)
    window.addEventListener('resize', updateBarVisibility, { passive: true });
    
    // Track CTA clicks
    var ctaBtn = document.getElementById('mobileBottomCTA');
    if (ctaBtn) {
        ctaBtn.addEventListener('click', function() {
            if (typeof gtag === 'function') {
                gtag('event', 'cta_click', { cta_type: 'assessment', location: 'mobile_bottom_bar' });
            }
        });
    }
})();

// Global close function - always available regardless of sessionStorage
window.closeExitModal = function() { var m = document.getElementById("exitModal"); if (m) { m.classList.remove("active"); document.body.style.overflow = ""; setTimeout(function() { m.remove(); }, 300); if (typeof gtag === "function") { gtag("event", "exit_intent_declined"); } } };

// P1: Exit-Intent Modal (IMPROVED: value preview, loading states, safer mobile trigger)
(function() {
    var exitShown = sessionStorage.getItem('alavanka-exit-shown');
    
    if (exitShown) return;
    
    function showExitModal() {
        if (document.getElementById('exitModal')) return;
        sessionStorage.setItem('alavanka-exit-shown', 'true');
        
        var lang = document.documentElement.lang === 'en' ? 'en' : 'pt';
        var copy = {
            pt: {
                title: 'Antes de ir...',
                subtitle: 'Receba o <strong>Playbook Fractional CRO 2025</strong> grátis',
                bullet1: '✓ Framework de diagnóstico GTM (25+ KPIs)',
                bullet2: '✓ Checklist de contratação de VP Sales',
                bullet3: '✓ Benchmarks de crescimento B2B Brasil',
                placeholder: 'Seu melhor email',
                cta: 'Enviar Playbook Gratuito',
                decline: 'Não, obrigado',
                disclaimer: '1 email/mês • Sem spam • Cancele quando quiser',
                sending: 'Enviando...',
                errorMsg: 'Erro ao enviar. Tente novamente.'
            },
            en: {
                title: 'Before you go...',
                subtitle: 'Get the <strong>Fractional CRO Playbook 2025</strong> free',
                bullet1: '✓ GTM diagnostic framework (25+ KPIs)',
                bullet2: '✓ VP Sales hiring checklist',
                bullet3: '✓ B2B growth benchmarks for Brazil',
                placeholder: 'Your best email',
                cta: 'Send Free Playbook',
                decline: 'No, thanks',
                disclaimer: '1 email/month • No spam • Unsubscribe anytime',
                sending: 'Sending...',
                errorMsg: 'Failed to send. Please try again.'
            }
        };
        var t = copy[lang];
        
        var modal = document.createElement('div');
        modal.className = 'exit-modal';
        modal.id = 'exitModal';
        modal.innerHTML = '<div class="exit-overlay"></div>' +
            '<div class="exit-content">' +
            '<button class="exit-close" aria-label="Fechar">&times;</button>' +
            '<div class="exit-book-icon" aria-hidden="true"><svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><path d="M8 7h8M8 11h6" opacity="0.5"/></svg></div>' +
            '<h3>' + t.title + '</h3>' +
            '<p>' + t.subtitle + '</p>' +
            '<ul class="exit-value-list">' +
            '<li>' + t.bullet1 + '</li>' +
            '<li>' + t.bullet2 + '</li>' +
            '<li>' + t.bullet3 + '</li>' +
            '</ul>' +
            '<form class="exit-form" id="exitForm">' +
            '<input type="email" name="user_mail" placeholder="' + t.placeholder + '" required autocomplete="email" id="exitEmailInput">' +
            '<button type="submit" class="exit-btn-primary" id="exitSubmitBtn">' + t.cta + '</button>' +
            '<div class="exit-error" id="exitError" style="display:none">' + t.errorMsg + '</div>' +
            '</form>' +
            '<button class="exit-btn-secondary">' + t.decline + '</button>' +
            '<span class="exit-disclaimer">' + t.disclaimer + '</span>' +
            '</div>';
        
        document.body.appendChild(modal);
        document.body.style.overflow = 'hidden';
        setTimeout(function() { modal.classList.add('active'); }, 10);
        
        modal.querySelector('.exit-overlay').addEventListener('click', function() { window.closeExitModal(); });
        modal.querySelector('.exit-close').addEventListener('click', function() { window.closeExitModal(); });
        modal.querySelector('.exit-btn-secondary').addEventListener('click', function() { window.closeExitModal(); });
        modal.querySelector('.exit-form').addEventListener('submit', function(e) { submitExitForm(e, t); });
        
        // ESC key to close
        document.addEventListener('keydown', handleEscKey);
        
        // Track (no PII)
        if (typeof gtag === 'function') {
            gtag('event', 'exit_intent_triggered', { event_category: 'engagement' });
        }
    }
    
    function handleEscKey(e) {
        if (e.key === 'Escape' || e.keyCode === 27) {
            closeExitModal();
        }
    }
    
    // Desktop: mouse leave (only when cursor exits top of viewport)
    document.addEventListener('mouseleave', function(e) {
        if (e.clientY <= 0 && !sessionStorage.getItem('alavanka-exit-shown') && window.scrollY > 800) {
            showExitModal();
        }
    });
    
    // Mobile: FIXED — only trigger on back-button-like behavior (scroll to near top after deep scroll)
    // Old logic fired on 2 rapid scroll-ups anywhere, causing accidental triggers.
    // New logic: user must have scrolled past 60% of page, then scroll back to top 15%.
    var maxScrollReached = 0;
    window.addEventListener('scroll', function() {
        var scrollPercent = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
        if (scrollPercent > maxScrollReached) maxScrollReached = scrollPercent;
        
        // Only trigger if they scrolled past 60% and are now near top
        if (maxScrollReached > 60 && scrollPercent < 15 && !sessionStorage.getItem('alavanka-exit-shown')) {
            showExitModal();
        }
    }, { passive: true });
})();

// Exit form submission (IMPROVED: loading state, error handling, no PII in GA4)
// NOTE: Uses getElementById instead of e.target.email to avoid Cloudflare email obfuscation
function submitExitForm(e, translations) {
    e.preventDefault();
    var emailInput = document.getElementById('exitEmailInput');
    if (!emailInput) return false;
    var emailVal = emailInput.value;
    if (!emailVal) return false;
    
    var submitBtn = document.getElementById('exitSubmitBtn');
    var errorDiv = document.getElementById('exitError');
    var originalText = submitBtn ? submitBtn.textContent : '';
    
    // Loading state
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = translations ? translations.sending : 'Enviando...';
        submitBtn.style.opacity = '0.7';
    }
    if (errorDiv) errorDiv.style.display = 'none';
    
    // Track conversion (NO email in GA4 — LGPD compliance)
    if (typeof gtag === 'function') {
        gtag('event', 'exit_email_capture', { event_category: 'conversion', event_label: 'playbook' });
    }
    
    // Send to Google Apps Script backend
    var payload = {
        source: 'exit_intent',
        email: emailVal,
        timestamp: new Date().toISOString(),
        page: window.location.pathname
    };
    
    // Show success immediately — the backend processes the POST before redirecting,
    // so even if CSP blocks the redirect response, the data is already saved.
    // Fire-and-forget: send request in background, don't wait for response.
    showExitSuccess(emailVal);
    
    try {
        // Try sendBeacon first (fire-and-forget, no CORS/CSP redirect issues)
        var sent = navigator.sendBeacon && navigator.sendBeacon(
            'https://script.google.com/macros/s/AKfycbyy_bNoqwbED3Fkn1N0H7xicE1wuTYMbhM7VG9wWHT4gMTracqCGEIgxy9qXzhnb2gF/exec',
            JSON.stringify(payload)
        );
        
        // Fallback: fetch with no-cors (request fires even if response is blocked)
        if (!sent) {
            fetch('https://script.google.com/macros/s/AKfycbyy_bNoqwbED3Fkn1N0H7xicE1wuTYMbhM7VG9wWHT4gMTracqCGEIgxy9qXzhnb2gF/exec', {
                method: 'POST',
                mode: 'no-cors',
                body: JSON.stringify(payload)
            }).catch(function() { /* fire-and-forget */ });
        }
    } catch(ignored) { /* fire-and-forget */ }
    
    return false;
}

function showExitSuccess(email) {
    var content = document.querySelector('#exitModal .exit-content');
    if (!content) return;
    content.innerHTML = '<div style="text-align:center;padding:40px 20px">' +
        '<svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2" style="margin:0 auto 16px;display:block">' +
        '<path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>' +
        '<h3 style="margin:0 0 8px;color:var(--accent);font-size:22px;font-family:Space Grotesk,sans-serif">Obrigado!</h3>' +
        '<p style="margin:0 0 20px;font-size:15px;color:var(--text-secondary)">Playbook enviado para<br><strong>' + email + '</strong></p>' +
        '<button onclick="closeExitModal()" style="padding:12px 24px;background:var(

    <!-- Google Analytics (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-D8LLY1L1Z3"></script>
    
    
    <!-- Microsoft Clarity -->
    <script type="text/javascript">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "vb4dciqpnm");
    </script>

    

</body>
</html>