<!-- Solution -->
<section id="solucao" class="solution-section">
    <div class="section-header">
        <h2 data-i18n="solution.title">Por Que Soluções <span class="hl">Tradicionais</span> Falham</h2>
    </div>
    
    <div class="comparison-table">
        <!-- Row 1: VP Sales vs Fractional -->
        <div class="comp-row">
            <div class="comp-cell comp-old">
                <span class="comp-label comp-label-fail">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    <span data-i18n="solution.traditional.label">Opção tradicional</span>
                </span>
                <h3 class="comp-title" data-i18n="solution.vp.title">Contratar VP Sales</h3>
                <p data-i18n="solution.vp.text">12-18 meses de ramp. ~50% taxa de falha em startups SaaS.* Custo de R$1M+/ano. Se não funcionar, você perdeu 18 meses.</p>
            </div>
            <div class="comp-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div class="comp-cell comp-new">
                <span class="comp-label comp-label-win">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span data-i18n="solution.fractional.label">Fractional CRO</span>
                </span>
                <h3 class="comp-title" data-i18n="solution.vp.better.title">Instalar arquitetura primeiro</h3>
                <p data-i18n="solution.vp.better.text">Contratar VP quando a máquina funcionar e você souber o perfil certo. 70% do impacto por 30% do custo.</p>
            </div>
        </div>
        
        <!-- Row 2: Consultoria vs Fractional -->
        <div class="comp-row">
            <div class="comp-cell comp-old">
                <span class="comp-label comp-label-fail">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    <span data-i18n="solution.traditional.label">Opção tradicional</span>
                </span>
                <h3 class="comp-title" data-i18n="solution.consulting.title">Consultoria Big 4</h3>
                <p data-i18n="solution.consulting.text">R$500k-1.5M por PowerPoints bonitos. Zero execução. Consultores juniores fazendo benchmarks genéricos.</p>
            </div>
            <div class="comp-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
            <div class="comp-cell comp-new">
                <span class="comp-label comp-label-win">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span data-i18n="solution.fractional.label">Fractional CRO</span>
                </span>
                <h3 class="comp-title" data-i18n="solution.consulting.better.title">Execução hands-on</h3>
                <p data-i18n="solution.consulting.better.text">2 dias/semana na operação. Metas semanais, não relatórios mensais. Pele no jogo com success fee.</p>
            </div>
        </div>
    </div>
    
    <!-- CTA Contextual - Após mostrar a solução -->
