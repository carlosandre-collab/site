<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
/* ══════════════════════════════════════════════════════════════════════════════
   i18n - Internationalization System
   Fix: Race condition quando nav.js dispara langChange antes do JSON carregar
   ══════════════════════════════════════════════════════════════════════════════ */
let currentLang = 'pt';
let translations = null; // null = não carregado ainda
let pendingLang = null;  // armazena mudança de idioma enquanto carrega

// Load translations from external file
fetch('translations.json')
    .then(response => response.json())
    .then(data => {
        translations = data;
        
        // Se houve mudança de idioma enquanto carregava, aplica agora
        if (pendingLang) {
            currentLang = pendingLang;
            pendingLang = null;
        } else {
            // Aplica idioma salvo se existir
            const saved = localStorage.getItem('alavanka-lang');
            if (saved && saved !== currentLang) {
                currentLang = saved;
            }
        }
        
        applyTranslations();
    })
    .catch(err => console.warn('Could not load translations:', err));

function toggleLang() {
    const newLang = currentLang === 'pt' ? 'en' : 'pt';
    
    if (!translations) {
        // JSON ainda não carregou - armazena para aplicar depois
        pendingLang = newLang;
        currentLang = newLang;
    } else {
        currentLang = newLang;
        applyTranslations();
    }
    
    localStorage.setItem('alavanka-lang', currentLang);
    
    // Atualiza botões de toggle
    const btnText = currentLang === 'pt' ? 'EN' : 'PT';
    const langText = document.getElementById('langText');
    const langBtn = document.getElementById('langToggle');
    const langBtnMobile = document.getElementById('langToggleMobile');
    if (langText) langText.textContent = btnText;
    if (langBtn) langBtn.textContent = btnText;
    if (langBtnMobile) langBtnMobile.textContent = btnText;
    
    // GA4: Track language switch (Tag 18)
    if (typeof gtag === 'function') {
        gtag('event', 'language_changed', { language: currentLang });
    }
}

// Alias para compatibilidade
window.toggleLanguage = toggleLang;

function applyTranslations() {
    if (!translations) return;
    
    const t = translations[currentLang];
    if (!t) return;
    
    const btnText = currentLang === 'pt' ? 'EN' : 'PT';
    const langBtn = document.getElementById('langToggle');
    const langBtnMobile = document.getElementById('langToggleMobile');
    if (langBtn) langBtn.textContent = btnText;
    if (langBtnMobile) langBtnMobile.textContent = btnText;
    
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t[key]) {
            el.innerHTML = t[key];
        }
    });
    
    // Atualiza atributo lang do HTML
    document.documentElement.lang = currentLang === 'pt' ? 'pt-BR' : 'en';
}

// Listener para evento langChange da nav.js
window.addEventListener('langChange', function(e) {
    if (e.detail && e.detail.lang) {
        const newLang = e.detail.lang;
        
        if (!translations) {
            pendingLang = newLang;
            currentLang = newLang;
        } else {
            currentLang = newLang;
            applyTranslations();
        }
        
        localStorage.setItem('alavanka-lang', currentLang);
    }
});

document.addEventListener('DOMContentLoaded', () => {
    const saved = localStorage.getItem('alavanka-lang');
    if (saved) {
        currentLang = saved;
        const btnText = currentLang === 'pt' ? 'EN' : 'PT';
        const langBtn = document.getElementById('langToggle');
        const langBtnMobile = document.getElementById('langToggleMobile');
        if (langBtn) langBtn.textContent = btnText;
        if (langBtnMobile) langBtnMobile.textContent = btnText;
    }
});

// Audience Selector
// Audience Gate - selection from overlay popup
function selectAudience(audience, method) {
    // GA4: Track audience gate selection (Tags 1-3)
    if (typeof gtag === 'function') {
        var params = { audience_type: audience };
        if (method === 'skip') params.method = 'skip';
        gtag('event', 'audience_selected', params);
    }

    var gate = document.getElementById('audienceGate');
    if (gate) {
        gate.classList.add('closing');
        setTimeout(function() {
            gate.remove();
            document.body.style.overflow = '';
            setAudience(audience, true);
        }, 500);
    } else {
        setAudience(audience);
    }
}

// Apply audience choice
function setAudience(audience, shouldScroll) {
    sessionStorage.setItem('alavanka-audience', audience);
    
    if (audience === 'investor') {
        // Redirect to dedicated investors page
        window.location.href = 'investidores.html';
        return;
    }
    
    if (audience === 'international') {
        // Redirect to Market Entry Partnership page
        window.location.href = 'market-entry.html';
        return;
    }
    
    if (audience === 'other') {
        // Show neutral/default content without personalization
        document.body.classList.add('audience-other');
        
        // Optional: Show subtle notification
        showAudienceToast('💡 Conteúdo geral carregado. Você pode personalizar a qualquer momento.');
        
        return;
    }
    
    // Default: founder audience
    document.body.classList.add('audience-founder');
}

// Show toast notification
function showAudienceToast(message) {
    var toast = document.createElement('div');
    toast.className = 'audience-toast';
    toast.textContent = message;
    document.body.appendChild(toast);
    
    setTimeout(function() { toast.classList.add('visible'); }, 100);
    setTimeout(function() {
        toast.classList.remove('visible');
        setTimeout(function() { toast.remove(); }, 300);
    }, 5000);
}

// Gate initialization - skip if already selected in this session or coming from internal page
(function() {
    var savedAudience = sessionStorage.getItem('alavanka-audience');
    var ref = document.referrer || '';
    var isInternal = ref.indexOf('alavanka.com') !== -1;
    var gate = document.getElementById('audienceGate');

    if (savedAudience || isInternal) {
        // Already chose or came from internal page — skip gate
        if (gate) gate.remove();
        document.body.style.overflow = '';
        // Only auto-apply founder audience; investors have their own page
        if (savedAudience === 'founder') setAudience(savedAudience);
    } else {
        // First visit from external — show gate
        document.body.style.overflow = 'hidden';
    }
})();

// FAQ Toggle - Improved with proper height calculation
function toggleFaq(button) {
    const item = button.parentElement;
    const wasActive = item.classList.contains('active');
    const answer = item.querySelector('.faq-answer');
    const content = item.querySelector('.faq-answer-content');
    
    // Close all items
    document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('active');
        const a = i.querySelector('.faq-answer');
        if (a) a.style.maxHeight = '0';
    });
    
    // Open clicked item if it wasn't active
    if (!wasActive && answer && content) {
        item.classList.add('active');
        answer.style.maxHeight = content.scrollHeight + 24 + 'px';
        // GA4: Track FAQ opened (Tag 16)
        if (typeof gtag === 'function') {
            var items = Array.prototype.slice.call(document.querySelectorAll('.faq-item'));
            var idx = items.indexOf(item) + 1;
            gtag('event', 'faq_opened', { question: String(idx) });
        }
    }
}

// Dynamic Scroll Offset based on actual fixed header height
function getScrollOffset() {
    var nav = document.querySelector('nav');
    var offset = 16;
    if (nav) offset += nav.offsetHeight;
    return offset;
}

// Smooth Scroll - with dynamic offset
document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
            const pos = target.getBoundingClientRect().top + window.pageYOffset - getScrollOffset();
            window.scrollTo({ top: pos, behavior: 'smooth' });
        }
    });
});

// Intersection Observer for animations - uses data-observe attribute
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('animate-in');
            observer.unobserve(entry.target);
        }
    });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.pain-card, .consequence-card, .comp-row, .credential-card, .timeline-item, .fit-card, .faq-item, .logo-bar-item, .badge-item, .founder-profile, .founder-case-study, .founder-case-step').forEach(el => {
    el.setAttribute('data-observe', '');
    observer.observe(el);
});

// ── UX AUDIT ENHANCEMENTS ──

// A) Scroll-Reveal: smooth entrance for major blocks
const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); revealObs.unobserve(e.target); }
    });
}, { threshold: 0.08, rootMargin: '0px 0px -60px 0px' });
document.querySelectorAll('.section-header, .pain-intro, .urgency-box, .why-hero, .founder-profile, .founder-case-study, .cta-box, .inv-hero, .inv-scorecard, .inv-cost-section, .inv-case-study, .inv-solution, .inv-model, .inv-deliverables, .inv-cta-section, .authority-badges, .logo-bar-section, .inv-trust').forEach(el => {
    el.classList.add('reveal');
    revealObs.observe(el);
});

// B) Staggered reveal for card grids (consequence, inv-flag, inv-cost, inv-del, inv-model)
const cardRevealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
        if (e.isIntersecting) {
            const parent = e.target;
            const cards = parent.querySelectorAll('.consequence-card, .inv-flag, .inv-cost-card, .inv-del-item, .inv-model-card, .comp-row, .credential-card');
            cards.forEach((card, i) => {
                card.classList.add('reveal');
                setTimeout(() => card.classList.add('is-visible'), 80 * i);
            });
            cardRevealObs.unobserve(parent);
        }
    });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
document.querySelectorAll('.consequence-grid, .inv-scorecard-grid, .inv-cost-grid, .inv-del-grid, .inv-model-options, .comparison-table, .credentials-grid').forEach(el => {
    cardRevealObs.observe(el);
});

// C) Scroll Progress Bar — single handler at section D
// D) Mobile FAB: show after scrolling past hero
(function() {
    const fab = document.getElementById('mobileFab');
    if (!fab || window.innerWidth >= 768) return;
    let shown = false;
    document.body.classList.add('fab-active');
    window.addEventListener('scroll', function() {
        const threshold = window.innerHeight * 0.6;
        if (window.scrollY > threshold && !shown) {
            fab.classList.add('is-visible'); shown = true;
        } else if (window.scrollY <= threshold && shown) {
            fab.classList.remove('is-visible'); shown = false;
        }
    }, { passive: true });
})();

// E) Counter Animation: animate numeric values on scroll into view
(function() {
    function animateCounter(el, target, suffix, prefix, duration) {
        var start = 0, startTime = null;
        function step(ts) {
            if (!startTime) startTime = ts;
            var progress = Math.min((ts - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
            var current = Math.round(start + (target - start) * eased);
            el.textContent = (prefix || '') + current.toLocaleString() + (suffix || '');
            if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
    }
    
    // Enhanced parser for complex patterns like "$48M→$240M" and "150% YoY"
    function animateGrowthCard(el) {
        var original = el.innerHTML;
        // Pattern: "$48M→$240M" with optional <small> child
        var arrowMatch = el.textContent.match(/^\$?(\d+)M?\s*→\s*\$?(\d+)M/);
        if (arrowMatch) {
            var fromVal = parseInt(arrowMatch[1]);
            var toVal = parseInt(arrowMatch[2]);
            var smallEl = el.querySelector('small');
            var smallHTML = smallEl ? smallEl.outerHTML : '';
            var startTime = null;
            function stepArrow(ts) {
                if (!startTime) startTime = ts;
                var progress = Math.min((ts - startTime) / 1400, 1);
                var eased = 1 - Math.pow(1 - progress, 3);
                var curFrom = Math.round(fromVal * eased);
                var curTo = Math.round(toVal * eased);
                el.innerHTML = '$' + curFrom + 'M→$' + curTo + 'M' + smallHTML;
                if (progress < 1) requestAnimationFrame(stepArrow);
            }
            requestAnimationFrame(stepArrow);
            return;
        }
        // Pattern: "150% YoY"
        var pctMatch = el.textContent.match(/^(\d+)%\s*(.*)/);
        if (pctMatch) {
            var pctVal = parseInt(pctMatch[1]);
            var pctSuffix = pctMatch[2];
            var smallEl2 = el.querySelector('small');
            var smallHTML2 = smallEl2 ? smallEl2.outerHTML : '';
            animateCounter(el, pctVal, '% ' + pctSuffix + smallHTML2.replace(/<[^>]*>/g,''), '', 1200);
            // Restore small tag after animation
            if (smallEl2) {
                setTimeout(function(){
                    var text = el.textContent;
                    el.innerHTML = text.replace(smallEl2.textContent, '') + smallHTML2;
                }, 1250);
            }
            return;
        }
    }
    
    var counterObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) {
                var el = e.target;
                // Check if it's a growth card (complex format)
                if (el.classList.contains('growth')) {
                    animateGrowthCard(el);
                } else {
                    var text = el.textContent.trim();
                    // Parse patterns: "$240M", "67%", "$47M", "150%", "25+"
                    var match = text.match(/^([\$]?)(\d+)([\+%M]?)(.*)$/);
                    if (match) {
                        animateCounter(el, parseInt(match[2]), match[3] + match[4], match[1], 1200);
                    }
                }
                counterObs.unobserve(el);
            }
        });
    }, { threshold: 0.5 });

    document.querySelectorAll('.inv-stat-number').forEach(function(el) {
        var text = el.textContent.trim();
        if (/^\d+%?$/.test(text.replace(/[^0-9%]/g, ''))) counterObs.observe(el);
    });
    // MUDANÇA 2: Animate hero track-record numbers too
    document.querySelectorAll('.track-card .growth').forEach(function(el) {
        counterObs.observe(el);
    });
})();

// Progressive Disclosure — mobile only
function togglePD(btn) {
    var container = btn.closest('.pd-container');
    if (!container) return;
    var isCollapsed = container.classList.contains('pd-collapsed');
    container.classList.toggle('pd-collapsed');
    var label = btn.querySelector('span');
    if (label) {
        label.textContent = isCollapsed ? (btn.getAttribute('data-less') || 'Mostrar menos ↑') : (btn.getAttribute('data-more') || 'Ver mais ↓');
    }
    // GA4: Track progressive disclosure expand (Tag 19) — only on expand
    if (isCollapsed && typeof gtag === 'function') {
        var section = container.classList.contains('inv-scorecard-grid') ? 'scorecard' : 'deliverables';
        gtag('event', 'pd_expanded', { section: section });
    }
}

// Only enable PD on mobile — remove pd-collapsed on desktop
function checkPDBreakpoint() {
    var containers = document.querySelectorAll('.pd-container');
    var isMobile = window.innerWidth < 768;
    containers.forEach(function(c) {
        var toggle = c.querySelector('.pd-toggle');
        if (isMobile) {
            if (!c.classList.contains('pd-expanded')) {
                c.classList.add('pd-collapsed');
            }
            if (toggle) toggle.style.display = '';
        } else {
            c.classList.remove('pd-collapsed');
            if (toggle) toggle.style.display = 'none';
        }
    });
}
checkPDBreakpoint();
window.addEventListener('resize', checkPDBreakpoint);
</script>

<!-- GA4: CTA Click Tracking — Tags 4-14 -->
<script>
(function() {
    if (typeof gtag !== 'function') return;

    // Helper: find the closest <a> ancestor (or self)
    function closestLink(el) {
        while (el && el.tagName !== 'A') el = el.parentElement;
        return el;
    }

    document.addEventListener('click', function(e) {
        var link = closestLink(e.target);
        if (!link) return;

        var href = (link.getAttribute('href') || '').toLowerCase();
        var cls = ' ' + (link.className || '') + ' ';
        var params = null;

        // --- Assessment CTAs (Tags 4, 5) ---
        if (href.indexOf('assessment.html') !== -1) {
            if (cls.indexOf(' btn-hero') !== -1) {
                params = { cta_type: 'assessment', location: 'hero' };            // Tag 4
            } else if (cls.indexOf(' btn-section-cta') !== -1) {
                params = { cta_type: 'assessment', location: 'inline_consequences' }; // NEW
            } else {
                params = { cta_type: 'assessment', location: 'other' };
            }
        }
        // --- Calendly CTAs (Tags 6, 7, 8, 9) ---
        else if (href.indexOf('calendly') !== -1) {
            if (cls.indexOf(' hero-link') !== -1) {
                params = { cta_type: 'calendly', location: 'hero' };             // Tag 6
            } else if (cls.indexOf(' qualifier-cta') !== -1) {
                params = { cta_type: 'calendly', location: 'qualifier' };        // NEW - was assessment
            } else if (cls.indexOf(' btn-section-cta') !== -1) {
                params = { cta_type: 'calendly', location: 'inline_solution' };  // NEW
            } else if (cls.indexOf(' btn-primary') !== -1) {
                params = { cta_type: 'calendly', location: 'cta_final' };        // Tag 7
            } else if (cls.indexOf(' inv-cta-btn') !== -1 && cls.indexOf(' primary') !== -1) {
                params = { cta_type: 'calendly', location: 'investor' };         // Tag 8
            } else if (cls.indexOf(' fab-primary') !== -1) {
                params = { cta_type: 'calendly', location: 'fab_mobile' };       // Tag 9
            } else {
                params = { cta_type: 'calendly', location: 'other' };
            }
        }
        // --- WhatsApp CTAs (Tags 10, 11, 12) ---
        else if (href.indexOf('wa.me') !== -1) {
            if (cls.indexOf(' sec-link') !== -1) {
                params = { cta_type: 'whatsapp', location: 'cta_final' };        // Tag 10
            } else if (cls.indexOf(' fab-ghost') !== -1) {
                params = { cta_type: 'whatsapp', location: 'fab_mobile' };       // Tag 11
            } else if (cls.indexOf(' whatsapp-float') !== -1) {
                params = { cta_type: 'whatsapp', location: 'float' };            // Tag 12
            } else {
                params = { cta_type: 'whatsapp', location: 'contact_info' };
            }
        }
        // --- Email CTA (Tag 13) ---
        else if (href.indexOf('mailto:') !== -1 || href.indexOf('email-protection') !== -1) {
            params = { cta_type: 'email', location: 'contact_info' };            // Tag 13
        }
        // --- Guia Download — Investor (Tag 14) ---
        else if (href.indexOf('guia.alavanka') !== -1) {
            params = { cta_type: 'guia_download', location: 'investor' };        // Tag 14
        }

        if (params) {
            gtag('event', 'cta_click', params);
            // LinkedIn Conversion Tracking — fire for high-value CTAs
            if (typeof lintrk === 'function') {
                if (params.cta_type === 'calendly') {
                    lintrk('track', { conversion_id: 19814700 });
                } else if (params.cta_type === 'whatsapp') {
                    lintrk('track', { conversion_id: 19814716 });
                } else if (params.cta_type === 'guia_download') {
                    lintrk('track', { conversion_id: 19814732 });
                }
            }
        }
    });
})();
</script>

<!-- GA4: Engagement Tracking — Tags 15-20 -->
<script>
(function() {
    if (typeof gtag !== 'function') return;

    // --- Tag 15: Section Viewed (IntersectionObserver) ---
    var sectionIds = ['problema','solucao','porque','processo','contato','faq'];
    var viewedSections = {};
    var sectionObs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
            if (entry.isIntersecting) {
                var id = entry.target.id;
                if (!viewedSections[id]) {
                    viewedSections[id] = true;
                    gtag('event', 'section_viewed', { section: id });
                }
            }
        });
    }, { threshold: 0.3 });

    sectionIds.forEach(function(id) {
        var el = document.getElementById(id);
        if (el) sectionObs.observe(el);
    });

    // --- Tag 17: Scroll Depth Milestones ---
    var scrollMilestones = { 25: false, 50: false, 75: false, 100: false };
    window.addEventListener('scroll', function() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        var docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (docHeight <= 0) return;
        var percent = Math.round((scrollTop / docHeight) * 100);

        [25, 50, 75, 100].forEach(function(milestone) {
            if (percent >= milestone && !scrollMilestones[milestone]) {
                scrollMilestones[milestone] = true;
                gtag('event', 'scroll_depth', { depth: milestone });
            }
        });
    }, { passive: true });

    // --- Tag 20: Time on Page (30s, 60s, 120s, 300s) ---
    var timeIntervals = [30, 60, 120, 300];
    timeIntervals.forEach(function(seconds) {
        setTimeout(function() {
            gtag('event', 'time_on_page', { seconds: seconds });
        }, seconds * 1000);
    });
})();
</script>

<!-- Third-party scripts - deferred for better TBT -->
<script>
function loadThirdPartyScripts() {
    // LinkedIn Insight Tag
    window._linkedin_partner_id = "9076865";
    window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
    window._linkedin_data_partner_ids.push(window._linkedin_partner_id);
    
    if (!window.lintrk) {
        window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
        window.lintrk.q = [];
    }
    var s = document.getElementsByTagName("script")[0];
    var b = document.createElement("script");
    b.type = "text/javascript";
    b.async = true;
    b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
    s.parentNode.insertBefore(b, s);
}

// Load third-party scripts after page is interactive
if (document.readyState === 'complete') {
    loadThirdPartyScripts();
} else {
    window.addEventListener('load', loadThirdPartyScripts);
}
</script>
